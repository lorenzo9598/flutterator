import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:[[project_name]]/features/auth/sign_in_form/application/sign_in_form_bloc.dart';
import 'package:[[project_name]]/injection.dart';
import 'package:[[project_name]]/features/auth/sign_in_form/presentation/sign_in_form.dart';
import 'package:[[project_name]]/domain/auth/model/i_auth_facade.dart';

class LoginPage extends StatelessWidget {
  static const String routeName = '/login';
  static const String logoHeroTag = 'auth-logo';

  const LoginPage({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.transparent,
      body: BlocProvider<SignInFormBloc>(
        create: (BuildContext context) => SignInFormBloc(getIt<IAuthFacade>()),
        child: const SignInForm(),
      ),
    );
  }
}
