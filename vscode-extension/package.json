{
  "name": "flutterator",
  "displayName": "Flutterator",
  "description": "Interfaccia VS Code per il Flutterator CLI. Richiede il comando flutterator sul PC: pip install flutterator (e PATH che include lo script) oppure impostare flutterator.executablePath con il percorso completo dell'eseguibile.",
  "version": "0.1.1",
  "publisher": "lorenzobusi",
  "license": "MIT",
  "homepage": "https://pypi.org/project/flutterator/",
  "bugs": {
    "url": "https://github.com/lorenzo9598/flutterator/issues"
  },
  "icon": "media/logo.png",
  "keywords": [
    "flutter",
    "ddd",
    "codegen",
    "cli",
    "flutterator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lorenzo9598/flutterator.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:flutterator.create",
    "onCommand:flutterator.addPage",
    "onCommand:flutterator.addDomain",
    "onCommand:flutterator.addComponent",
    "onCommand:flutterator.addEnum",
    "onCommand:flutterator.showOutput"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Flutterator",
      "properties": {
        "flutterator.executablePath": {
          "type": "string",
          "default": "flutterator",
          "description": "Command or absolute path to the Flutterator CLI. Default assumes flutterator is on PATH (after pip install flutterator). Use an absolute path if the CLI is not on PATH."
        }
      }
    },
    "commands": [
      {
        "command": "flutterator.create",
        "title": "Flutterator: Create"
      },
      {
        "command": "flutterator.addPage",
        "title": "Flutterator: Add Page"
      },
      {
        "command": "flutterator.addDomain",
        "title": "Flutterator: Add Domain"
      },
      {
        "command": "flutterator.addComponent",
        "title": "Flutterator: Add Component"
      },
      {
        "command": "flutterator.addEnum",
        "title": "Flutterator: Add Enum"
      },
      {
        "command": "flutterator.showOutput",
        "title": "Flutterator: Show Output"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "flutterator.submenu",
          "when": "explorerResourceIsFolder",
          "group": "navigation@100"
        }
      ],
      "flutterator.submenu": [
        {
          "command": "flutterator.addPage",
          "when": "explorerResourceIsFolder",
          "args": [
            "${resource}"
          ]
        },
        {
          "command": "flutterator.addDomain",
          "when": "explorerResourceIsFolder",
          "args": [
            "${resource}"
          ]
        },
        {
          "command": "flutterator.addComponent",
          "when": "explorerResourceIsFolder",
          "args": [
            "${resource}"
          ]
        },
        {
          "command": "flutterator.addEnum",
          "when": "explorerResourceIsFolder",
          "args": [
            "${resource}"
          ]
        }
      ]
    },
    "submenus": [
      {
        "id": "flutterator.submenu",
        "label": "Flutterator"
      }
    ],
    "keybindings": [
      {
        "command": "flutterator.showOutput",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish:vsce": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3"
  }
}
